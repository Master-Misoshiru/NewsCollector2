# Discord のウェブフックURL（GitHub Secrets に DISCORD_WEBHOOK_URL として登録してください）
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Google Gemini API キー（日本語要約に使用。GitHub Secrets に GOOGLE_API_KEY として登録してください）
# 無料枠あり: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY
